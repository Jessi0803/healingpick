# AI provider: anthropic or gemini
AI_PROVIDER=anthropic

# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Gemini API (OpenAI-compatible endpoint)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash

# Google Drive postcards for personal Google Drive OAuth uploads
GOOGLE_DRIVE_POSTCARD_FOLDER_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Postcard pilot controls. Use "*" to enable for every signed-in member.
POSTCARD_PILOT_EMAILS=baby90522@gmail.com
POSTCARD_RETURN_DEDUPE_MINUTES=1
