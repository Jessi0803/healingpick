# AI provider: anthropic or gemini
AI_PROVIDER=anthropic

# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Gemini API (OpenAI-compatible endpoint)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash

# Optional postcard image pool. Add 20 comma-separated Google Drive file IDs
# to make each member rotate through all 20 postcards before repeating.
POSTCARD_IMAGE_IDS=

# Resend email sending
RESEND_API_KEY=
RESEND_FROM_EMAIL="Healing Pick <hello@example.com>"
